# ============================================================
# eMenu Smart Tags — required environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# ----------------------------------------------------------
# REQUIRED: Anthropic API key
# Used by: Phase 2 LLM tag extraction (claude-sonnet-4-6),
#          sentiment analysis, and structured output.
# Get yours at https://console.anthropic.com/
# ----------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ----------------------------------------------------------
# REQUIRED: Phone hashing salt
# Used by: guest_history_lookup.py to SHA-256 hash phone
#          numbers before storage.  Must be a long random
#          string unique to this deployment — changing it
#          invalidates all existing phone hashes.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ----------------------------------------------------------
PHONE_HASH_SALT=replace-with-a-random-64-char-hex-string

# ----------------------------------------------------------
# REQUIRED in production, optional in development
# Database URL for SQLAlchemy.
# Dev default (SQLite, created automatically): omit or set to
#   sqlite:///./emenu_smart_tags.db
# Production (Postgres on Render):
#   postgresql://user:password@host:5432/dbname
# ----------------------------------------------------------
DATABASE_URL=sqlite:///./emenu_smart_tags.db

# ----------------------------------------------------------
# OPTIONAL: Groq API key
# Secondary LLM provider, used only when GROQ_ENABLED=true.
# Kept for backwards compatibility; Claude is the primary LLM.
# ----------------------------------------------------------
GROQ_API_KEY=gsk_...

# ----------------------------------------------------------
# OPTIONAL: LLM tag pipeline behaviour
#
# LLM_TAGS_REQUIRED — When "true", a missing/broken ANTHROPIC_API_KEY
#   causes POST /api/v1/reservations/analyze-tags-v2 to return HTTP 503
#   instead of silently falling back to the regex safety-net.
#   Default: unset (fallback allowed).
#
# GROQ_ENABLED — set to "true" to route tag extraction to
#   Groq instead of Claude (fallback path only).
# ----------------------------------------------------------
LLM_TAGS_REQUIRED=false
GROQ_ENABLED=false
