# ═══════════════════════════════════════════════════════════
# eMenu Smart Tags — Environment Variables
# ═══════════════════════════════════════════════════════════

# API Backend URL (used by frontend in production)
VITE_API_URL=https://smart-tags-predictor.onrender.com

# ── Supabase Cloud Sync (Optional) ────────────────────────
# Enable persistent cross-device history by connecting to Supabase.
# Without these, history is stored in browser localStorage only.
#
# 1. Create a free project at https://supabase.com
# 2. Run supabase/migration.sql in the SQL Editor
# 3. Copy your Project URL and anon key from Settings > API
#
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
